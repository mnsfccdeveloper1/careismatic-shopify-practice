  {%- comment -%} Components {%- endcomment -%}
  <section class="mb-12">
    <h2 class="fs-display-3 mb-6 pb-2 border-b border-black">Components</h2>

    <div class="mb-8">
      <h3 class="fs-display-5 mb-4 text-grey-dark">Accordion</h3>
      <div class="max-w-prose">
        <accordion-block>
          <details>
            <summary>What is your return policy?</summary>
            <div class="pb-4">
              <p>We offer a 30-day return policy on all unworn items. Items must be in their original packaging with tags attached.</p>
            </div>
          </details>
        </accordion-block>
        <accordion-block>
          <details>
            <summary>How long does shipping take?</summary>
            <div class="pb-4">
              <p>Standard shipping takes 5–7 business days. Expedited shipping is available at checkout for 2–3 business day delivery.</p>
            </div>
          </details>
        </accordion-block>
        <accordion-block>
          <details open>
            <summary>Do you offer bulk ordering?</summary>
            <div class="pb-4">
              <p>Yes, we offer bulk discounts for orders of 12 or more units. Contact our sales team for a custom quote.</p>
            </div>
          </details>
        </accordion-block>
      </div>
    </div>
  </section>

  {%- comment -%} Media Loader {%- endcomment -%}
  <section class="mb-12">
    <div role="heading" aria-level="2" class="fs-display-3 mb-6 pb-2 border-b border-black">Media Loader</div>
    <p class="fs-body-sm text-grey-medium mb-4">Wraps media and shows a pulsing skeleton until it loads. Reload the page to see the skeleton state.</p>

    {%- capture media_loader_content -%}
      {%- if demo_product.featured_image -%}
        {{ demo_product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'size-full object-cover' }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'size-full object-cover' }}
      {%- endif -%}
    {%- endcapture -%}
    <div class="aspect-[3/2] w-64 rounded-theme overflow-hidden">
      {% render 'media-loader', content: media_loader_content, show_skeleton: true %}
    </div>
  </section>

  {%- comment -%} Horizontal Scroll (custom-scroll) {%- endcomment -%}
  <section class="mb-12">
    <div role="heading" aria-level="2" class="fs-display-3 mb-6 pb-2 border-b border-black">Horizontal Scroll</div>
    <p class="fs-body-sm text-grey-medium mb-4"><code>&lt;custom-scroll&gt;</code> adds click-and-drag horizontal scrolling (mouse only) to any overflowing element. Wrap a <code>[data-custom-scroll-track]</code> child and optional <code>[data-action-scroll-prev]</code> / <code>[data-action-scroll-next]</code> buttons — each button shows only while you can scroll that way. The buttons are positioned absolutely over the track so showing/hiding them doesn't shift the row. Drag the row or use the buttons.</p>

    <custom-scroll class="relative block">
      <button
        type="button"
        data-action-scroll-prev
        aria-label="Scroll left"
        class="hidden absolute left-1 top-1/2 -translate-y-1/2 z-10 flex-center size-9 rounded-full border border-grey bg-white text-grey-dark shadow-sm [&>svg]:size-4">
        {{- 'icon-angle-left.svg' | inline_asset_content -}}
      </button>
      <div
        data-custom-scroll-track
        class="flex gap-4 overflow-x-auto no-scrollbar py-2 cursor-grab active:cursor-grabbing">
        {%- for i in (1..12) -%}
          <div class="flex-center shrink-0 w-40 h-28 bg-grey-light border border-grey rounded-theme fs-display-4">
            {{ i }}
          </div>
        {%- endfor -%}
      </div>
      <button
        type="button"
        data-action-scroll-next
        aria-label="Scroll right"
        class="hidden absolute right-1 top-1/2 -translate-y-1/2 z-10 flex-center size-9 rounded-full border border-grey bg-white text-grey-dark shadow-sm [&>svg]:size-4">
        {{- 'icon-angle-right.svg' | inline_asset_content -}}
      </button>
    </custom-scroll>
  </section>

  {%- comment -%} Dialogs & Drawers {%- endcomment -%}
  <section class="mb-12">
    <div role="heading" aria-level="2" class="fs-display-3 mb-6 pb-2 border-b border-black">Dialogs &amp; Drawers</div>
    <p class="fs-body-sm text-grey-medium mb-4">Each is a native <code>&lt;dialog&gt;</code> wrapped in <code>&lt;openable-component&gt;</code> (close on backdrop click / Escape / the X button).</p>

    <div class="flex flex-wrap gap-4">
      <button type="button" class="button" data-styleguide-dialog="styleguide-dialog-r">Right Drawer</button>
      <button type="button" class="button" data-styleguide-dialog="styleguide-dialog-l">Left Drawer</button>
      <button type="button" class="button" data-styleguide-dialog="styleguide-dialog-t">Top Drawer</button>
      <button type="button" class="button" data-styleguide-dialog="styleguide-dialog-b">Bottom Drawer</button>
      <button type="button" class="button" data-styleguide-dialog="styleguide-dialog-popup">Popup</button>
    </div>

    {%- assign dialog_variants = 'r-drawer,l-drawer,t-drawer,b-drawer,popup' | split: ',' -%}
    {%- for variant in dialog_variants -%}
      {%- assign dialog_key = variant | split: '-' | first -%}
      <openable-component data-close-on-outside-click data-close-on-escape-key>
        <dialog id="styleguide-dialog-{{ dialog_key }}" data-openable class="dialog-{{ variant }} bg-white p-8" aria-label="{{ variant }} example">
          {% render 'dialog-close-button', position: 'absolute' %}
          <div role="heading" aria-level="2" class="fs-display-4 mb-2">dialog-{{ variant }}</div>
          <p class="fs-body-md max-w-prose">Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit.</p>
        </dialog>
      </openable-component>
    {%- endfor -%}

    <script>
      (function () {
        document.querySelectorAll('[data-styleguide-dialog]').forEach(function (trigger) {
          trigger.addEventListener('click', function () {
            var dialog = document.getElementById(this.dataset.styleguideDialog);
            if (dialog && !dialog.open) dialog.showModal();
          });
        });
      })();
    </script>
  </section>

  {%- comment -%} Data Components {%- endcomment -%}
  <section class="mb-12">
    <div role="heading" aria-level="2" class="fs-display-3 mb-6 pb-2 border-b border-black">Data Components</div>
    <p class="fs-body-sm text-grey-medium mb-6">Rendered from a demo product/collection ({{ demo_collection.title | default: 'none found' }}). These appear empty on a store with no products.</p>

    <div class="mb-8">
      <div role="heading" aria-level="3" class="fs-display-5 mb-1 text-grey-dark">Product Card</div>
      <code class="fs-body-sm text-grey-medium block mb-4">{% raw %}{% render 'product-card' %}{% endraw %}</code>
      {%- if demo_product -%}
        <div class="w-64">
          {% render 'product-card', product: demo_product, collection_context: demo_collection %}
        </div>
      {%- else -%}
        <p class="fs-body-sm text-grey-medium">No demo product available in this store.</p>
      {%- endif -%}
    </div>

    <div class="mb-8">
      <div role="heading" aria-level="3" class="fs-display-5 mb-1 text-grey-dark">Product Card — Horizontal</div>
      <code class="fs-body-sm text-grey-medium block mb-4">{% raw %}{% render 'product-card-horizontal' %}{% endraw %}</code>
      {%- comment -%} The quick-shop button targets #quick-shop-dialog (only on PDP/collection); inert here, card renders fine. {%- endcomment -%}
      {%- if demo_product -%}
        <div class="max-w-3xl">
          {% render 'product-card-horizontal', product: demo_product %}
        </div>
      {%- else -%}
        <p class="fs-body-sm text-grey-medium">No demo product available in this store.</p>
      {%- endif -%}
    </div>

    <div class="mb-8">
      <div role="heading" aria-level="3" class="fs-display-5 mb-4 text-grey-dark">Product Price</div>
      {%- if demo_product -%}
        <div class="space-y-3">
          <div>
            <span class="fs-body-sm text-grey-medium block mb-1">Product (target: product)</span>
            {% render 'product-price', target: demo_product %}
          </div>
          <div>
            <span class="fs-body-sm text-grey-medium block mb-1">Variant (target: variant)</span>
            {% render 'product-price', target: demo_product.selected_or_first_available_variant %}
          </div>
        </div>
      {%- else -%}
        <p class="fs-body-sm text-grey-medium">No demo product available in this store.</p>
      {%- endif -%}
    </div>

    <div class="mb-8">
      <div role="heading" aria-level="3" class="fs-display-5 mb-1 text-grey-dark">Product Card Swatches</div>
      <code class="fs-body-sm text-grey-medium block mb-4">{% raw %}{% render 'product-card-swatches' %}{% endraw %}</code>
      {%- comment -%} The <product-option> fetcher is inert without a parent product-card; visual only. {%- endcomment -%}
      {%- if demo_product -%}
        <div class="w-64">
          {% render 'product-card-swatches', product: demo_product, collection_context: demo_collection %}
        </div>
      {%- else -%}
        <p class="fs-body-sm text-grey-medium">No demo product available in this store.</p>
      {%- endif -%}
    </div>

    <div class="mb-8">
      <div role="heading" aria-level="3" class="fs-display-5 mb-1 text-grey-dark">Article Card</div>
      <code class="fs-body-sm text-grey-medium block mb-4">{% raw %}{% render 'article-card' %}{% endraw %}</code>
      {%- if demo_article -%}
        <div class="w-72">
          {% render 'article-card', article: demo_article, blog: demo_blog %}
        </div>
      {%- else -%}
        <p class="fs-body-sm text-grey-medium">No demo article available in this store.</p>
      {%- endif -%}
    </div>

    <div>
      <div role="heading" aria-level="3" class="fs-display-5 mb-4 text-grey-dark">Product Carousel</div>
      {%- if demo_collection.products.size > 0 -%}
        {% render 'product-carousel', carousel_collection: demo_collection, heading: 'Product Carousel', products_to_show: 8 %}
      {%- else -%}
        <p class="fs-body-sm text-grey-medium">No demo collection products available in this store.</p>
      {%- endif -%}
    </div>
  </section>

  {%- comment -%} Localization {%- endcomment -%}
  <section class="mb-12">
    <h2 class="fs-display-3 mb-6 pb-2 border-b border-black">Localization</h2>

    <div class="mb-8">
      <div role="heading" aria-level="3" class="fs-display-5 mb-1 text-grey-dark">Country/region selector</div>
      <code class="fs-body-sm text-grey-medium block mb-4">{% raw %}{% form 'localization' %}{% endraw %}</code>

      <div style="max-width: 300px;">
        {% form 'localization', class: 'w-full' %}
          <div class="mb-md">
            <label for="styleguide-localization-country" class="fs-display-5 block mb-2xs">
              Country/region
            </label>

            <select
              id="styleguide-localization-country"
              name="country_code"
              class="form-input"
              onchange="this.form.submit()"
            >
              {% for country in localization.available_countries %}
                <option
                  value="{{ country.iso_code }}"
                  {% if country.iso_code == localization.country.iso_code %}selected{% endif %}
                >
                  {{- country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                </option>
              {% endfor %}
            </select>
          </div>

          <button type="submit" class="button button-lg w-full">Update</button>
        {% endform %}
      </div>
    </div>
  </section>
</div>
