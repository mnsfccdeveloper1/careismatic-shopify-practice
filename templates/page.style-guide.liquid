<!-- template: page.style-guide -->
{%- liquid
  assign demo_collection = collections['all']
  if demo_collection == empty or demo_collection.products.size == 0
    assign demo_collection = collections.all
  endif
  assign demo_product = demo_collection.products.first
  assign demo_blog = blogs.first
  assign demo_article = demo_blog.articles.first
-%}
<div class="container py-8">
  <h1 class="fs-display-1 mb-8">Style Guide</h1>

  {%- comment -%} Font Families {%- endcomment -%}
  <section class="mb-12">
    <h2 class="fs-display-3 mb-6 pb-2 border-b border-black">Font Families</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {%- comment -%} GT Walsheim {%- endcomment -%}
      <div class="border border-grey-light p-6 font-display">
        <p class="fs-body-sm text-grey-medium mb-1 font-body">Display Font</p>
        <p class="fs-display-3">GT Walsheim</p>
        <p class="fs-body-sm text-grey-medium mb-4 font-body">Black (900)</p>
        <div class="space-y-3">
          <div>
            <span class="fs-body-sm text-grey-medium block mb-1 font-body">Uppercase</span>
            <p class="text-lg font-display">ABCDEFGHIJKLMNOPQRSTUVWXYZ</p>
          </div>
          <div>
            <span class="fs-body-sm text-grey-medium block mb-1 font-body">Lowercase</span>
            <p class="text-lg font-display">abcdefghijklmnopqrstuvwxyz</p>
          </div>
          <div>
            <span class="fs-body-sm text-grey-medium block mb-1 font-body">Numbers</span>
            <p class="ftext-lg font-display">0123456789</p>
          </div>
          <div>
            <span class="fs-body-sm text-grey-medium block mb-1 font-body">Characters</span>
            <p class="text-lg font-display">!@#$%^&amp;*()_+-=[]{}|;:&rsquo;,./&lt;&gt;?</p>
          </div>
        </div>
      </div>

      {%- comment -%} Inter {%- endcomment -%}
      <div class="border border-grey-light p-6 font-body">
        <p class="fs-body-sm text-grey-medium mb-1">Body Font</p>
        <p class="text-3xl font-body">Inter</p>
        <p class="fs-body-sm text-grey-medium mb-4">Regular (400) · Medium (500)</p>
        <div class="space-y-3">
          <div>
            <span class="fs-body-sm text-grey-medium block mb-1">Uppercase</span>
            <p class="fs-display-5">ABCDEFGHIJKLMNOPQRSTUVWXYZ</p>
          </div>
          <div>
            <span class="fs-body-sm text-grey-medium block mb-1">Lowercase</span>
            <p class="fs-display-5">abcdefghijklmnopqrstuvwxyz</p>
          </div>
          <div>
            <span class="fs-body-sm text-grey-medium block mb-1">Numbers</span>
            <p class="fs-display-5">0123456789</p>
          </div>
          <div>
            <span class="fs-body-sm text-grey-medium block mb-1">Characters</span>
            <p class="fs-display-5">!@#$%^&amp;*()_+-=[]{}|;:&rsquo;,./&lt;&gt;?</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Typography {%- endcomment -%}
  <section class="mb-12">
    <h2 class="fs-display-3 mb-6 pb-2 border-b border-black">Typography</h2>

    <div class="mb-8">
      <h3 class="fs-display-5 mb-4 text-grey-dark">Display Headings</h3>
      <div class="space-y-4">
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Display 1 (fs-display-1)</span>
          <p class="fs-display-1">The quick brown fox jumps over the lazy dog</p>
        </div>
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Display 2 (fs-display-2)</span>
          <p class="fs-display-2">The quick brown fox jumps over the lazy dog</p>
        </div>
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Display 3 (fs-display-3)</span>
          <p class="fs-display-3">The quick brown fox jumps over the lazy dog</p>
        </div>
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Display 4 (fs-display-4)</span>
          <p class="fs-display-4">The quick brown fox jumps over the lazy dog</p>
        </div>
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Display 5 (fs-display-5)</span>
          <p class="fs-display-5">The quick brown fox jumps over the lazy dog</p>
        </div>
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Display 6 (fs-display-6)</span>
          <p class="fs-display-6">The quick brown fox jumps over the lazy dog</p>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <div role="heading" aria-level="3" class="fs-display-5 mb-4 text-grey-dark">Eyebrow</div>
      <div>
        <span class="fs-body-sm text-grey-medium block mb-1">Eyebrow (fs-eyebrow)</span>
        <p class="fs-eyebrow">New Arrivals</p>
      </div>
    </div>

    <div class="mb-8">
      <h3 class="fs-display-5 mb-4 text-grey-dark">Body Text</h3>
      <div class="space-y-4 max-w-prose">
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Body Large (fs-body-lg) · Regular</span>
          <p class="fs-body-lg">Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit. Exercitation veniam consequat sunt nostrud amet.</p>
        </div>
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Body Large (fs-body-lg) · Medium</span>
          <p class="fs-body-lg font-medium">Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit. Exercitation veniam consequat sunt nostrud amet.</p>
        </div>
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Body Medium (fs-body-md) · Regular</span>
          <p class="fs-body-md">Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit. Exercitation veniam consequat sunt nostrud amet.</p>
        </div>
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Body Medium (fs-body-md) · Medium</span>
          <p class="fs-body-md font-medium">Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit. Exercitation veniam consequat sunt nostrud amet.</p>
        </div>
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Body Small (fs-body-sm) · Regular</span>
          <p class="fs-body-sm">Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit. Exercitation veniam consequat sunt nostrud amet.</p>
        </div>
        <div>
          <span class="fs-body-sm text-grey-medium block mb-1">Body Small (fs-body-sm) · Medium</span>
          <p class="fs-body-sm font-medium">Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit. Exercitation veniam consequat sunt nostrud amet.</p>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Buttons {%- endcomment -%}
  <section class="mb-12">
    <h2 class="fs-display-3 mb-6 pb-2 border-b border-black">Buttons</h2>

    <div class="mb-8">
      <h3 class="fs-display-5 mb-4 text-grey-dark">Primary</h3>
      <div class="bg-white p-6 mb-4">
        <div class="flex flex-wrap gap-4 items-center">
          <button class="button">Primary Button</button>
          <button class="button" disabled>Disabled</button>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <h3 class="fs-display-5 mb-4 text-grey-dark">Secondary</h3>
      <div class="bg-black p-6">
        <div class="flex flex-wrap gap-4 items-center">
          <button class="button button-secondary">Secondary Button</button>
          <button class="button button-secondary" disabled>Disabled</button>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <h3 class="fs-display-5 mb-4 text-grey-dark">Outline Black</h3>
      <div class="bg-white p-6 mb-4">
        <div class="flex flex-wrap gap-4 items-center">
          <button class="button button-outline-black">Outline Black</button>
          <button class="button button-outline-black" disabled>Disabled</button>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <h3 class="fs-display-5 mb-4 text-grey-dark">Outline White</h3>
      <div class="bg-black p-6">
        <div class="flex flex-wrap gap-4 items-center">
          <button class="button button-outline-white">Outline White</button>
          <button class="button button-outline-white" disabled>Disabled</button>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <h3 class="fs-display-5 mb-4 text-grey-dark">Arrow Button</h3>
      <div class="bg-white p-6 mb-4">
        <div class="flex flex-wrap gap-4 items-center">
          <a href="" class="arrow-button">
            <span>Arrow Button</span>
            <span>
              {{- 'icon-arrow-right.svg' | inline_asset_content -}}
            </span>
          </a>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <h3 class="fs-display-5 mb-4 text-grey-dark">Underline Button</h3>
      <div class="bg-white p-6 mb-4">
        <div class="flex flex-wrap gap-4 items-center">
          <a href="" class="underline-button">Underline Button</a>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Chips {%- endcomment -%}
  <section class="mb-12">
    <div role="heading" aria-level="2" class="fs-display-3 mb-6 pb-2 border-b border-black">Chips</div>

    {%- comment -%} Chips are scheme-aware: they resolve --color-chip-* tokens, so demos must sit inside a color-* wrapper. {%- endcomment -%}
    <div class="color-{{ settings.color_schemes.first.id }} bg-white p-6">
      <div class="mb-8">
        <span class="fs-body-sm text-grey-medium block mb-2">Default (.chip)</span>
        <div class="flex flex-wrap gap-2 items-center">
          <span class="chip">Scrubs</span>
          <span class="chip">Lab Coats</span>
          <span class="chip">Footwear</span>
        </div>
      </div>

      <div>
        <span class="fs-body-sm text-grey-medium block mb-2">Active (.chip.chip--active)</span>
        <div class="flex flex-wrap gap-2 items-center">
          <span class="chip chip--active">Scrubs</span>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Badges & Labels {%- endcomment -%}
  <section class="mb-12">
    <div role="heading" aria-level="2" class="fs-display-3 mb-6 pb-2 border-b border-black">Badges &amp; Labels</div>

    <div class="mb-8">
      <div role="heading" aria-level="3" class="fs-display-5 mb-4 text-grey-dark">Badges</div>
      <div class="bg-white p-6">
        <div class="flex flex-wrap gap-3 items-center">
          <span class="badge badge-sale inline-block py-1 px-2 rounded-[2px] text-nowrap">Sale</span>
          <span class="badge badge-low-stock inline-block py-1 px-2 rounded-[2px] text-nowrap">Low Stock</span>
          <span class="badge badge-sold-out inline-block py-1 px-2 rounded-[2px] text-nowrap">Sold Out</span>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <div role="heading" aria-level="3" class="fs-display-5 mb-4 text-grey-dark">Labels</div>
      <div class="bg-white p-6">
        <div class="flex flex-wrap gap-3 items-center">
          <span class="label">New</span>
          <span class="label">Best Seller</span>
          <span class="label">Exclusive</span>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Colors {%- endcomment -%}
  <section class="mb-12">
    <h2 class="fs-display-3 mb-6 pb-2 border-b border-black">Colors</h2>

    <div class="flex flex-wrap gap-4 mb-4">
      <div class="text-center">
        <div class="w-20 h-20 bg-black border border-grey-light"></div>
        <span class="fs-body-sm">Black</span>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-white border border-grey-light"></div>
        <span class="fs-body-sm">White</span>
      </div>
    </div>

    <div class="flex flex-wrap gap-4 mb-4">
      <div class="text-center">
        <div class="w-20 h-20 bg-grey-dark border border-grey-light"></div>
        <span class="fs-body-sm">Gray Dark</span>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-grey-medium border border-grey-light"></div>
        <span class="fs-body-sm">Gray Medium</span>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-grey border border-grey-light"></div>
        <span class="fs-body-sm">Gray</span>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-grey-light border border-grey-light"></div>
        <span class="fs-body-sm">Gray Light</span>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-grey-light-blue border border-grey-light"></div>
        <span class="fs-body-sm">Gray Light Blue</span>
      </div>
    </div>

    <div class="flex flex-wrap gap-4">
      <div class="text-center">
        <div class="w-20 h-20 bg-brand-blue border border-grey-light"></div>
        <span class="fs-body-sm">Brand Blue</span>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-midnight-blue border border-grey-light"></div>
        <span class="fs-body-sm">Midnight Blue</span>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-electric-blue border border-grey-light"></div>
        <span class="fs-body-sm">Electric Blue</span>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-optimistic-blue border border-grey-light"></div>
        <span class="fs-body-sm">Optimistic Blue</span>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-red-sale border border-grey-light"></div>
        <span class="fs-body-sm">Red Sale</span>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 bg-danger border border-grey-light"></div>
        <span class="fs-body-sm">Danger</span>
      </div>
    </div>

    <div class="mt-8">
      <h3 class="fs-display-5 mb-4 text-grey-dark">Color Schemes</h3>

      <div class="mb-6">
        <label for="styleguide-color-scheme" class="form-label">Select a color scheme</label>
        <select class="form-input" id="styleguide-color-scheme" style="max-width: 20rem;">
          {%- for scheme in settings.color_schemes -%}
            <option value="color-{{ scheme.id }}"{% if forloop.first %} selected{% endif %}>{{ scheme.id }}</option>
          {%- endfor -%}
        </select>
      </div>

      <div id="styleguide-color-scheme-preview" class="color-{{ settings.color_schemes.first.id }} p-8 border border-grey-light rounded-lg">
        <div class="max-w-prose space-y-6">

          <div>
            <h4 class="fs-display-3">Heading Example</h4>
          </div>

          <div>
            <p class="fs-body-md">Amet minim mollit non deserunt ullamco est sit aliqua dolor do amet sint. Velit officia consequat duis enim velit mollit. Exercitation veniam consequat sunt nostrud amet.</p>
          </div>

          <div class="flex flex-wrap gap-4 items-center">
            <button class="button">Primary Button</button>
            <button class="button button-secondary">Secondary Button</button>
          </div>

          <div>
            <span class="fs-body-sm block mb-2 opacity-60">Chips (scheme tokens)</span>
            <div class="flex flex-wrap gap-2 items-center">
              <span class="chip">Default Chip</span>
              <span class="chip">Another Tag</span>
              <span class="chip chip--active">Active Chip</span>
            </div>
          </div>

          <div class="input-field" style="max-width: 20rem;">
            <label for="styleguide-cs-input">Input Label</label>
            <input id="styleguide-cs-input" type="text" placeholder="Input Label">
          </div>

          <div>
            <accordion-block class="accordion--first">
              <details>
                <summary>What is your return policy?</summary>
                <div><p class="fs-body-md">We offer a 30-day return policy on all unworn items. Items must be in their original packaging with tags attached.</p></div>
              </details>
            </accordion-block>
            <accordion-block>
              <details>
                <summary>How long does shipping take?</summary>
                <div><p class="fs-body-md">Standard shipping takes 5–7 business days. Expedited shipping is available at checkout for 2–3 business day delivery.</p></div>
              </details>
            </accordion-block>
            <accordion-block>
              <details>
                <summary>Do you offer bulk ordering?</summary>
                <div><p class="fs-body-md">Yes, we offer bulk discounts for orders of 12 or more units. Contact our sales team for a custom quote.</p></div>
              </details>
            </accordion-block>
          </div>

        </div>
      </div>

      <script>
        (function() {
          var select = document.getElementById('styleguide-color-scheme');
          var preview = document.getElementById('styleguide-color-scheme-preview');
          if (!select || !preview) return;

          select.addEventListener('change', function() {
            preview.className = preview.className.replace(/\bcolor-\S+/g, '');
            preview.classList.add(this.value);
          });
        })();
      </script>
    </div>
  </section>

  {%- comment -%} Spacing {%- endcomment -%}
  <section class="mb-12">
    <div role="heading" aria-level="2" class="fs-display-3 mb-6 pb-2 border-b border-black">Spacing</div>
    <p class="fs-body-sm text-grey-medium mb-4">Values are responsive — they scale up at the <code>lg</code> breakpoint.</p>

    <div class="space-y-3">
      <div>
        <span class="fs-body-sm text-grey-medium block mb-1">2XS (--spacing-2xs)</span>
        <div class="bg-brand-blue h-6" style="width: var(--spacing-2xs);"></div>
      </div>
      <div>
        <span class="fs-body-sm text-grey-medium block mb-1">XS (--spacing-xs)</span>
        <div class="bg-brand-blue h-6" style="width: var(--spacing-xs);"></div>
      </div>
      <div>
        <span class="fs-body-sm text-grey-medium block mb-1">SM (--spacing-sm)</span>
        <div class="bg-brand-blue h-6" style="width: var(--spacing-sm);"></div>
      </div>
      <div>
        <span class="fs-body-sm text-grey-medium block mb-1">MD (--spacing-md)</span>
        <div class="bg-brand-blue h-6" style="width: var(--spacing-md);"></div>
      </div>
      <div>
        <span class="fs-body-sm text-grey-medium block mb-1">LG (--spacing-lg)</span>
        <div class="bg-brand-blue h-6" style="width: var(--spacing-lg);"></div>
      </div>
    </div>
  </section>

  {%- comment -%} Border Radius {%- endcomment -%}
  <section class="mb-12">
    <div role="heading" aria-level="2" class="fs-display-3 mb-6 pb-2 border-b border-black">Border Radius</div>

    <div class="flex flex-wrap gap-8">
      <div class="text-center">
        <div class="w-32 h-20 bg-grey-light border border-grey rounded-theme"></div>
        <span class="fs-body-sm text-grey-medium block mt-1">rounded-theme</span>
      </div>
      <div class="text-center">
        <div class="w-32 h-20 bg-grey-light border border-grey rounded-theme-sm"></div>
        <span class="fs-body-sm text-grey-medium block mt-1">rounded-theme-sm</span>
      </div>
    </div>
  </section>

  {%- comment -%} Form Elements {%- endcomment -%}
  <section class="mb-12">
    <h2 class="fs-display-3 mb-6 pb-2 border-b border-black">Form Elements</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      <fieldset>
        <legend class="fs-display-4 font-bold uppercase mb-4">Text Fields</legend>

        <div class="input-field mb-8">
          <label for="styleguide-input-text-empty">Empty</label>
          <input
            id="styleguide-input-text-empty"
            type="text"
            placeholder="Empty"
          >
        </div>

        <div class="input-field mb-8">
          <label for="styleguide-input-text-filled">Filled</label>
          <input
            id="styleguide-input-text-filled"
            type="text"
            placeholder="Filled"
            value="Value"
          >
        </div>

        <div class="input-field mb-8">
          <label for="styleguide-input-text-disabled">Disabled</label>
          <input
            id="styleguide-input-text-disabled"
            type="text"
            placeholder="Disabled"
            value="Disabled value"
            disabled
          >
        </div>
      </fieldset>

      <fieldset>
        <legend class="fs-display-4 font-bold uppercase mb-4">Quantity Input</legend>

        <div class="mb-4">
          <label for="styleguide-quantity" class="form-label">Normal</label>
          <div class="h-12" style="max-width: 8rem;">
            <quantity-input class="quantity-input">
              <button
                class="quantity-input__button"
                data-quantity-input-decrease
                type="button"
                aria-label="Decrease quantity"
              >
                {{- 'icon-minus.svg' | inline_asset_content -}}
              </button>
              <input
                class="quantity-input__input"
                type="number"
                id="styleguide-quantity"
                value="1"
                min="1"
                max="99"
              >
              <button
                class="quantity-input__button"
                type="button"
                data-quantity-input-increase
                aria-label="Increase quantity"
              >
                {{- 'icon-plus.svg' | inline_asset_content -}}
              </button>
            </quantity-input>
          </div>
        </div>

        <div class="mb-4">
          <label for="styleguide-quantity-disabled" class="form-label">Disabled</label>
          <div class="h-12" style="max-width: 8rem;">
            <quantity-input class="quantity-input">
              <button
                class="quantity-input__button"
                data-quantity-input-decrease
                type="button"
                aria-label="Decrease quantity"
                disabled
              >
                {{- 'icon-minus.svg' | inline_asset_content -}}
              </button>
              <input
                class="quantity-input__input"
                type="number"
                id="styleguide-quantity-disabled"
                value="3"
                min="1"
                max="99"
                disabled
              >
              <button
                class="quantity-input__button"
                type="button"
                data-quantity-input-increase
                aria-label="Increase quantity"
                disabled
              >
                {{- 'icon-plus.svg' | inline_asset_content -}}
              </button>
            </quantity-input>
          </div>
        </div>
      </fieldset>

      <fieldset>
        <legend class="fs-display-4 font-bold uppercase mb-4">Select</legend>

        <div class="mb-4">
          <label for="styleguide-select" class="form-label">Normal</label>
          <select class="form-input" id="styleguide-select">
            <option>Option 1</option>
            <option>Option 2</option>
            <option>Option 3</option>
          </select>
        </div>

        <div class="mb-4">
          <label for="styleguide-select-disabled" class="form-label">Disabled</label>
          <select class="form-input" id="styleguide-select-disabled" disabled>
            <option>Option 1</option>
            <option>Option 2</option>
            <option>Option 3</option>
          </select>
        </div>
      </fieldset>

