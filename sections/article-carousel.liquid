<!-- section: article-carousel -->

{%- liquid
  assign s = section.settings

  assign articles_to_render = s.article_list
  if articles_to_render == blank
    assign articles_to_render = s.blog.articles
  endif
-%}

<section class="color-{{ s.color_scheme }}">
  <div class="pt-section pb-section">

    {% unless s.hide_header %}
      <div class="px-gutter flex justify-between items-center mb-sm">
        <div class="flex flex-col gap-2">
          {% if s.heading != blank %}
            <div role="heading" aria-level="2" class="fs-display-3">{{ s.heading | escape }}</div>
          {% endif %}
          {% if s.text != blank %}
            <div class="rte max-w-180 text-pretty">{{ s.text }}</div>
          {% endif %}
        </div>
        {% if s.button_link != blank and s.button_text != blank %}
          {% render 'arrow-button', url: s.button_link, text: s.button_text %}
        {% endif %}
      </div>
    {% endunless %}

    {% if articles_to_render != blank %}
      <tarot-carousel class="group lg:px-gutter">

        <div class="px-gutter relative">
          {%- assign prev_class = 'flex absolute z-2 opacity-0 group-hover:opacity-100 transition-opacity left-4' -%}
          {%- assign next_class = 'flex absolute z-2 opacity-0 group-hover:opacity-100 transition-opacity right-4' -%}
          {% render 'carousel-buttons',
            prev_class: prev_class,
            next_class: next_class
          %}
        </div>

        <script type="application/json" data-tarot-options>
          {
            "effect": "carousel",
            "loop": {{ s.loop | json }},
            "gap": "16px",
            "paddingLeft": "20px",
            "slidesPerView": {{ s.slides_per_view_mobile | json }},
            "navigation": {
              "showButtons": false,
              "showPagination": true,
              "smartButtons": true
            },
            "breakpoints": {
              "768": {
                "gap": "16px",
                "slidesPerView": {{ s.slides_per_view_tablet | json }},
                "navigation": {
                  "showPagination": false,
                  "showButtons": true
                }
              },
              "1024": {
                "gap": "16px",
                "paddingLeft": 0,
                "slidesPerView": {{ s.slides_per_view_laptop | json }},
                "navigation": {
                  "showPagination": false,
                  "showButtons": true
                }
              },
              "1280": {
                "gap": "16px",
                "paddingLeft": 0,
                "slidesPerView": {{ s.slides_per_view_desktop | json }},
                "navigation": {
                  "showPagination": false,
                  "showButtons": true
                }
              }
            }
          }
        </script>

        <tarot-viewport>
          <tarot-track>
            {% for article in articles_to_render limit: 12 %}
              <tarot-slide>
                {% render 'article-card',
                  article: article,
                  blog: s.blog,
                  show_image: s.show_image,
                  show_date: s.show_date,
                  show_author: s.show_author
                %}
              </tarot-slide>
            {% endfor %}
          </tarot-track>
        </tarot-viewport>

        <div data-tarot-pagination class="py-sm md:hidden"></div>

      </tarot-carousel>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Articles carousel",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the blog"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "checkbox",
      "id": "hide_header",
      "label": "Hide header",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop carousel",
      "default": false
    },
    {
      "type": "header",
      "content": "Articles",
      "info": "Hand-picked articles override the selected blog. Leave the list empty to show the blog's latest articles."
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "article_list",
      "id": "article_list",
      "label": "Articles",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show author",
      "default": false
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View all"
    },
    {
      "type": "header",
      "content": "Slides per view",
      "info": "Decimal values (e.g. 1.3) show a partial next card to hint there's more."
    },
    {
      "type": "range",
      "id": "slides_per_view_mobile",
      "label": "Mobile",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 1.3
    },
    {
      "type": "range",
      "id": "slides_per_view_tablet",
      "label": "Tablet",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 2.3
    },
    {
      "type": "range",
      "id": "slides_per_view_laptop",
      "label": "Laptop",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 3.3
    },
    {
      "type": "range",
      "id": "slides_per_view_desktop",
      "label": "Desktop",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 3.3
    }
  ],
  "presets": [
    {
      "name": "Articles carousel",
      "category": "Media & Content"
    }
  ],
  "disabled_on": {
    "groups": ["*"]
  }
}
{% endschema %}
