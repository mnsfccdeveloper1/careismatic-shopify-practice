<!-- section: faq-content -->
{%- liquid
  assign s = section.settings
  assign first_heading = ''
  for b in section.blocks
    if b.type == 'heading' and first_heading == ''
      assign first_heading = b.settings.heading
    endif
  endfor
-%}

<section class="color-{{ s.color_scheme }} pb-lg">
  <faq-content class="container max-w-[1212px] block">

    {% #  Mobile dropdown nav  %}
    <sticky-content class="pt-sm">
      <openable-component
        data-close-on-outside-click
        data-close-on-escape-key
        class="lg:hidden z-10 block mb-sm transform-y-header-stuck">
      <details data-openable class="bg-white border border-black/10 rounded-xs  [&[open]_svg]:rotate-180">
        <summary class="flex items-center justify-between gap-2 p-4 cursor-pointer">
          <span data-faq-nav-current 
            class="fs-body">{{ first_heading | escape }}</span>
          <span class="shrink-0 transition-transform duration-200 size-4">
            {{ 'icon-angle-down.svg' | inline_asset_content }}
          </span>
        </summary>
        <ul class="absolute top-full px-4 pb-3 border-t border-black/10 flex flex-col bg-white w-full border border-black/10 ml-[-1px]">
          {%- for block in section.blocks -%}
            {%- if block.type == 'heading' -%}
              <li>
                <button
                  type="button"
                  class="w-full text-left py-2 fs-body"
                  data-faq-nav-target="faq-block-{{ block.id }}"
                >{{ block.settings.heading | escape }}</button>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </details>
      </openable-component>
    </sticky-content>

    {% #  Desktop two-column layout  %}
    <div class="lg:flex lg:gap-lg lg:items-start">

      {% #  Sticky side nav  %}
      <nav
        class="hidden lg:block lg:w-[336px] lg:shrink-0 sticky top-[100px] py-md"
        aria-label="FAQ sections" >
        <ul class="flex flex-col gap-4">
          {%- for block in section.blocks -%}
            {%- if block.type == 'heading' -%}
              <li>
                <button
                  type="button"
                  class="button-bullet"
                  data-faq-nav-target="faq-block-{{ block.id }}"
                >
                  <span></span>
                  {{ block.settings.heading | escape }}
                </button>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </nav>

      {% #  Content column  %}
      <div class="w-full max-w-[824px]">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              <div
                {{ block.shopify_attributes }}
                id="faq-block-{{ block.id }}"
                data-faq-heading
                role="heading"
                aria-level="2"
                class="fs-display-4 pt-md pb-xs"
              >{{ block.settings.heading | escape }}</div>
            {%- when 'qa' -%}
              <accordion-block {{ block.shopify_attributes }} class="accordion">
                <details>
                  <summary>{{ block.settings.question | escape }}</summary>
                  <div class="rte text-pretty">{{ block.settings.answer }}</div>
                </details>
              </accordion-block>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </faq-content>
</section>

{% schema %}
{
  "name": "FAQ content",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Section heading"
        }
      ]
    },
    {
      "type": "qa",
      "name": "Q&A",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Sample question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Sample answer.</p>"
        }
      ]
    }
  ]
}
{% endschema %}
