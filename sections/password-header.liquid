<!-- section: password-header -->

<section class="flex min-h-dvh flex-1 items-center justify-center px-gutter py-md">
  <div class="flex w-full max-w-[35rem] flex-col gap-md rounded-theme border border-black/5 bg-white p-md shadow-lg">

    {% # Logo %}
    <a href="{{ routes.root_url }}" class="mx-auto block h-6">
      {%- if settings.logo_colored != blank -%}
        {{-
          settings.logo_colored
          | image_url: width: 340
          | image_tag: alt: shop.name, class: 'h-6 w-auto object-contain'
        -}}
        <span class="sr-only">{{- shop.name | escape -}}</span>
      {%- else -%}
        <span class="fs-display-4">{{- shop.name | escape -}}</span>
      {%- endif -%}
    </a>

    {% # Heading + subtext %}
    <div class="flex flex-col gap-xs">
      <div role="heading" aria-level="1" class="fs-display-3 uppercase">{{ 'password.login_form.title' | t }}</div>
      <p class="fs-body-md">{{ 'password.login_form.subtext' | t }}</p>
    </div>

    {% # Password form %}
    {%- form 'storefront_password' -%}
      <div class="flex flex-col gap-md">
        <div class="input-field">
          <label for="password">{{ 'password.login_form.password' | t }}</label>
          <input
            type="password"
            name="password"
            id="password"
            required
            aria-required="true"
            autocomplete="current-password"
            placeholder="{{ 'password.login_form.password' | t }}"
            {% if form.errors %}aria-invalid="true" aria-describedby="password-error"{% endif %}
          >
        </div>
        {%- if form.errors -%}
          <small id="password-error" class="fs-body-sm text-[var(--color-red-error)]">
            {{- form.errors | default_errors -}}
          </small>
        {%- endif -%}
        <button type="submit" class="button button-lg w-full">{{ 'password.login_form.submit' | t }}</button>
      </div>
    {%- endform -%}

  </div>
</section>

{% schema %}
{
  "name": "Password Header"
}
{% endschema %}
