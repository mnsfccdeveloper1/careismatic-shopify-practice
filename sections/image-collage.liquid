<!-- section: image-collage -->

{%- liquid
  assign s = section.settings

  # Layout
  assign outer_class = ''
  if s.add_padding
    assign outer_class = 'py-md px-gutter'
    if s.width == 'container'
      assign outer_class = 'max-w-container mx-auto py-md px-gutter'
    endif
  endif

  assign grid_gap = ''
  if s.add_padding
    assign grid_gap = 'gap-2'
  endif

  assign card_rounded = ''
  if s.add_padding
    assign card_rounded = 'rounded-theme'
  endif
-%}

<section class="color-{{ s.color_scheme }}">
  <div class="{{ outer_class }}">
    {% if section.blocks.size > 0 %}
      <div class="grid grid-cols-1 lg:grid-cols-2 {{ grid_gap }}">

        {% for block in section.blocks %}
          {%- liquid
            assign b = block.settings

            assign has_video = false
            if b.video.sources != blank
              assign has_video = true
            endif

            assign has_image = false
            if b.image != blank
              assign has_image = true
            endif

            assign poster = b.image | default: b.video.preview_image

            assign show_button_1 = false
            if b.button_1_text != blank and b.button_1_link != blank
              assign show_button_1 = true
            endif

            assign show_button_2 = false
            if b.button_2_text != blank and b.button_2_link != blank
              assign show_button_2 = true
            endif

            assign button_count = 0
            if show_button_1
              assign button_count = button_count | plus: 1
            endif
            if show_button_2
              assign button_count = button_count | plus: 1
            endif
          -%}

          <div
            class="relative color-{{ b.color_scheme }} bg-scheme text-scheme overflow-hidden {{ card_rounded }}"
            style="height: {{ s.section_height }}vh;"
            {{ block.shopify_attributes }}>

            {% if has_video %}
              {% for source in b.video.sources %}
                {% if source.url contains 'mp4' %}
                  <video
                    class="absolute inset-0 w-full h-full object-cover"
                    autoplay
                    playsinline
                    muted
                    loop
                    preload="none"
                    poster="{{ poster | image_url: width: 1600 }}"
                    type="video/mp4"
                    src="{{ source.url }}"></video>
                  {% break %}
                {% endif %}
              {% endfor %}
            {% elsif has_image %}
              <div class="absolute inset-0">
                {%- capture content -%}
                  {{- b.image
                    | image_url: width: 1600
                    | image_tag:
                        class: 'w-full h-full object-cover',
                        loading: 'lazy',
                        sizes: '(min-width: 1024px) 50vw, 100vw',
                        widths: '600, 900, 1200, 1600'
                  -}}
                {%- endcapture -%}
                {%- render 'media-loader', content: content, show_skeleton: true -%}
              </div>
            {% else %}
              <div class="absolute inset-0">
                {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full object-cover' }}
              </div>
            {% endif %}

            {% if b.overlay_opacity > 0 %}
              <div
                class="absolute inset-0 pointer-events-none"
                style="background-color: {{ b.overlay_color }}; opacity: {{ b.overlay_opacity | divided_by: 100.0 }};">
              </div>
            {% endif %}

            {% if b.eyebrow != blank or b.heading != blank %}
              <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-md">
                {% if b.eyebrow != blank %}
                  <p class="fs-eyebrow mb-2xs">{{ b.eyebrow | escape }}</p>
                {% endif %}
                {% if b.heading != blank %}
                  <div role="heading" aria-level="2" class="fs-display-2 text-pretty">
                    {{ b.heading | escape }}
                  </div>
                {% endif %}
              </div>
            {% endif %}

            {% if button_count > 0 %}
              <div class="absolute inset-x-0 bottom-0 p-md flex gap-4 {% if button_count == 1 %}justify-center{% endif %}">
                {% if show_button_1 %}
                  <a
                    class="{{ b.button_1_style }} {% if button_count == 1 %}w-full max-w-[290px]{% else %}flex-1{% endif %}"
                    href="{{ b.button_1_link }}">
                    {{ b.button_1_text | escape }}
                  </a>
                {% endif %}
                {% if show_button_2 %}
                  <a
                    class="{{ b.button_2_style }} {% if button_count == 1 %}w-full max-w-[290px]{% else %}flex-1{% endif %}"
                    href="{{ b.button_2_link }}">
                    {{ b.button_2_text | escape }}
                  </a>
                {% endif %}
              </div>
            {% endif %}

          </div>
        {% endfor %}

      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Image Collage",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme" },

    { "type": "header", "content": "Layout" },
    {
      "type": "checkbox",
      "id": "add_padding",
      "label": "Add padding",
      "info": "Adds padding around the section, gap between cards, and rounds card corners.",
      "default": false
    },
    {
      "type": "select",
      "id": "width",
      "label": "Max width",
      "options": [
        { "value": "full-width", "label": "Full width" },
        { "value": "container", "label": "Container" }
      ],
      "default": "container",
      "visible_if": "{{ section.settings.add_padding == true }}"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 30,
      "max": 100,
      "step": 5,
      "default": 70,
      "unit": "vh"
    }
  ],
  "max_blocks": 2,
  "blocks": [
    {
      "type": "content",
      "name": "Content card",
      "settings": [
        { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme" },

        { "type": "header", "content": "Media" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "video", "id": "video", "label": "Video", "info": "Plays muted with autoplay and loop. Takes priority over image when set." },

        { "type": "header", "content": "Overlay" },
        { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#000000" },
        { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "default": 0, "unit": "%" },

        { "type": "header", "content": "Content" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Collage heading" },

        { "type": "header", "content": "Button 1" },
        { "type": "text", "id": "button_1_text", "label": "Button text" },
        { "type": "url", "id": "button_1_link", "label": "Button link" },
        {
          "type": "select",
          "id": "button_1_style",
          "label": "Button style",
          "options": [
            { "value": "button", "label": "Primary" },
            { "value": "button button-secondary", "label": "Secondary" },
            { "value": "button button-outline-black", "label": "Outline black" },
            { "value": "button button-outline-white", "label": "Outline white" }
          ],
          "default": "button"
        },

        { "type": "header", "content": "Button 2" },
        { "type": "text", "id": "button_2_text", "label": "Button text" },
        { "type": "url", "id": "button_2_link", "label": "Button link" },
        {
          "type": "select",
          "id": "button_2_style",
          "label": "Button style",
          "options": [
            { "value": "button", "label": "Primary" },
            { "value": "button button-secondary", "label": "Secondary" },
            { "value": "button button-outline-black", "label": "Outline black" },
            { "value": "button button-outline-white", "label": "Outline white" }
          ],
          "default": "button button-outline-white"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Collage",
      "category": "Media & Content",
      "blocks": [
        { "type": "content" },
        { "type": "content" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["*"]
  }
}
{% endschema %}
