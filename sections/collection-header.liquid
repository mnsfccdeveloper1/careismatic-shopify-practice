<!-- section: collection-header -->

{%- liquid
  assign s = section.settings

  # collection has description
  assign has_description = false
  if collection.description != blank
    assign has_description = true
  endif

  # layout — container gets desktop gutters + rounded corners, full width is edge to edge
  # mobile is always edge to edge either way
  assign wrapper_class = ''
  assign gutter_class = ''
  assign rounded_class = ''
  if s.width == 'container'
    assign wrapper_class = 'max-w-container mx-auto'
    assign gutter_class = ' lg:px-gutter '
    assign rounded_class = 'lg:rounded-theme'
  endif

  # collection has image
  assign has_image = false
  if collection.image
    assign has_image = true
  endif

  assign section_class = ''
  assign active_color_scheme = s.color_scheme
  if has_image
    assign section_class = 'lg:mb-section'
    assign active_color_scheme = s.image_color_scheme
  endif

  # collection is empty
  assign empty_text_class = ''
  if collection.products.size == 0
    assign empty_text_class = 'text-center'
  endif

  # matching men's/women's collection switcher
  assign womens_collection = collection.metafields.meta.matching_womens_collection.value
  assign mens_collection = collection.metafields.meta.matching_mens_collection.value
  assign show_switcher = false
  if womens_collection != blank or mens_collection != blank
    assign show_switcher = true
  endif

  # switcher gap — wider when using the text-style buttons
  assign switcher_gap_class = 'gap-3'
  if s.active_button_style == 'underline-button' or s.active_button_style == 'text-link' or s.linked_button_style == 'underline-button' or s.linked_button_style == 'text-link'
    assign switcher_gap_class = 'gap-4'
  endif

  # centered content + buttons
  assign content_align_class = ''
  assign row_justify_class = ''
  assign button_row_class = 'flex mt-6 ' | append: switcher_gap_class
  if s.center_content
    assign content_align_class = ' text-center items-center'
    assign row_justify_class = ' justify-center'
    assign button_row_class = button_row_class | append: ' justify-center'
  endif
-%}



<section class="{{ section_class }} {{ gutter_class }}">

  <div class="{{ wrapper_class }}">
    <div class="relative overflow-hidden {{ rounded_class }} 
      color-{{ active_color_scheme }}">

      {%- if collection.products.size == 0 -%}

        <div class="flex-center py-10 lg:py-20">
          <div>
            <h1 class="fs-display-2 text-center">
              {{- collection.title | escape -}}
            </h1>
            {%- if show_switcher -%}
              <div class="flex mt-6 justify-center {{ switcher_gap_class }}">
                {%- if womens_collection != blank -%}
                  <a href="{{ womens_collection.url }}" class="{{ s.linked_button_style }}">Women</a>
                  <span class="{{ s.active_button_style }} non-clickable" aria-current="page">Men</span>
                {%- else -%}
                  <span class="{{ s.active_button_style }} non-clickable" aria-current="page">Women</span>
                  <a href="{{ mens_collection.url }}" class="{{ s.linked_button_style }}">Men</a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>

      {%- elsif has_image -%}

        <div class="absolute inset-0 w-full h-full">
          {%- capture content -%}
            {{- collection.image | image_url: width: 1920 | image_tag:
              class: 'w-full h-full object-cover',
              loading: 'eager',
              fetchpriority: 'high',
              sizes: '100vw',
              widths: '600, 900, 1200, 1440, 1920'
            -}}
          {%- endcapture -%}
          {%- render 'media-loader', content: content, show_skeleton: true -%}
        </div>

        <div class="container relative z-10 flex items-center h-[250px] 
          lg:h-[453px] py-md lg:py-lg {{ row_justify_class }}">
          <div class="flex flex-col gap-2 lg:gap-6 max-w-[620px]{{ content_align_class }}">
            <div>
              <h1 class="fs-display-2 text-pretty">
                {{- collection.title | escape -}}
              </h1>
              {%- if show_switcher -%}
                <div class="{{ button_row_class }}">
                  {%- if womens_collection != blank -%}
                    <a href="{{ womens_collection.url }}" class="{{ s.linked_button_style }}">Women</a>
                    <span class="{{ s.active_button_style }} non-clickable" aria-current="page">Men</span>
                  {%- else -%}
                    <span class="{{ s.active_button_style }} non-clickable" aria-current="page">Women</span>
                    <a href="{{ mens_collection.url }}" class="{{ s.linked_button_style }}">Men</a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
            {%- if has_description -%}
              <div class="text-pretty">
                <rte-content class="rte">{{- collection.description -}}</rte-content>
              </div>
            {%- endif -%}
          </div>
        </div>

      {%- else -%}

        <div class="flex items-center px-gutter py-6 lg:py-10 lg:px-0 {{ row_justify_class }}">
          <div class="flex flex-col gap-2 lg:gap-6{{ content_align_class }}">
            <div>
              <h1 class="fs-display-2">
                {{- collection.title | escape -}}
              </h1>
              {%- if show_switcher -%}
                <div class="{{ button_row_class }}">
                  {%- if womens_collection != blank -%}
                    <a href="{{ womens_collection.url }}" class="{{ s.linked_button_style }}">Women</a>
                    <span class="{{ s.active_button_style }} non-clickable" aria-current="page">Men</span>
                  {%- else -%}
                    <span class="{{ s.active_button_style }} non-clickable" aria-current="page">Women</span>
                    <a href="{{ mens_collection.url }}" class="{{ s.linked_button_style }}">Men</a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
            {%- if has_description -%}
              <div>
                <rte-content class="rte">{{- collection.description -}}</rte-content>
              </div>
            {%- endif -%}
          </div>
        </div>

      {%- endif -%}

    </div>
  </div>
</section>

{% render 'subcollections-list', collection: collection %}

{% schema %}
{
  "name": "Collection Header",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "color_scheme",
      "id": "image_color_scheme",
      "label": "Image color scheme"
    },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
        { "value": "full-width", "label": "Full width" },
        { "value": "container", "label": "Container" }
      ],
      "info": "Container adds side gutters and rounded corners on desktop. Mobile is always edge to edge.",
      "default": "container"
    },
    {
      "type": "checkbox",
      "id": "center_content",
      "label": "Center content and buttons",
      "default": false
    },

    { "type": "header", "content": "Men/Women switcher" },
    {
      "type": "select",
      "id": "active_button_style",
      "label": "Active button style",
      "options": [
        { "value": "button", "label": "Primary" },
        { "value": "button button-secondary", "label": "Secondary" },
        { "value": "button button-outline-black", "label": "Outline black" },
        { "value": "button button-outline-white", "label": "Outline white" },
        { "value": "underline-button", "label": "Underline" },
        { "value": "text-link", "label": "Text link" }
      ],
      "default": "button"
    },
    {
      "type": "select",
      "id": "linked_button_style",
      "label": "Linked button style",
      "options": [
        { "value": "button", "label": "Primary" },
        { "value": "button button-secondary", "label": "Secondary" },
        { "value": "button button-outline-black", "label": "Outline black" },
        { "value": "button button-outline-white", "label": "Outline white" },
        { "value": "underline-button", "label": "Underline" },
        { "value": "text-link", "label": "Text link" }
      ],
      "default": "button button-outline-black"
    }
  ]
}
{% endschema %}
