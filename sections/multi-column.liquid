<!-- section: multi-column -->
{%- assign s = section.settings -%}

<section class="color-{{ s.color_scheme }} py-lg">
  <div class="container">

    {%- if s.heading != blank -%}
      <div 
        role="heading"
        aria-level="2"
        class="fs-display-2 mb-8 lg:mb-12">
        {{- s.heading | escape -}}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        {%- for block in section.blocks -%}
          {%- liquid
            assign b = block.settings

            assign has_video = false
            if b.video.sources != blank
              assign has_video = true
            endif

            assign poster = b.image | default: b.video.preview_image
          -%}
          <div class="pb-4" {{ block.shopify_attributes }}>

            {%- if has_video -%}
              <div class="overflow-hidden rounded-theme aspect-[4/3]">
                {%- for source in b.video.sources -%}
                  {%- if source.url contains 'mp4' -%}
                    <video
                      class="w-full h-full object-cover"
                      autoplay
                      playsinline
                      muted
                      loop
                      preload="none"
                      poster="{{ poster | image_url: width: 960 }}"
                      type="video/mp4"
                      src="{{ source.url }}"></video>
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- elsif b.image != blank -%}
              <div class="overflow-hidden rounded-theme aspect-[4/3]">
                {%- capture content -%}
                  {{- b.image | image_url: width: 960 | image_tag:
                    class: 'w-full h-full object-cover',
                    loading: 'lazy',
                    sizes: '(min-width: 1024px) 33vw, 100vw',
                    widths: '300, 450, 600, 750, 960'
                  -}}
                {%- endcapture -%}
                {%- render 'media-loader', content: content, show_skeleton: true -%}
              </div>
            {%- endif -%}

            {%- if b.title != blank -%}
              <div 
                role="heading"
                aria-level="3"
                class="fs-display-5 mt-5 text-base">
                  {{- b.title | escape -}}
              </div>
            {%- endif -%}

            {%- if b.text != blank -%}
              <div class="rte mt-[13px] text-grey-dark">{{- b.text -}}</div>
            {%- endif -%}

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Multi Column",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Multi Column"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Plays muted with autoplay and loop. Takes priority over image when set."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Column"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Multi Column",
      "category": "Media & Content",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
