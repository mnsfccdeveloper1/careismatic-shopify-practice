<!-- section: shop-the-look -->

{%- liquid
  assign s = section.settings
  assign uid = section.id | split: '_' | last
  assign image_carousel_id = 'stl-image-' | append: uid
  assign content_carousel_id = 'stl-content-' | append: uid
  assign show_nav = false
  if section.blocks.size > 1
    assign show_nav = true
  endif
-%}

<section class="">
  <div class="max-w-container mx-auto color-{{ s.color_scheme }}">

    {% if section.blocks.size > 0 %}
      <div class="grid grid-cols-1 lg:grid-cols-2 items-center">

        {% # Left column — image carousel %}
        <div class="relative">
          <tarot-carousel id="{{ image_carousel_id }}" class="block relative">
            <script type="application/json" data-tarot-options>
              {
                "effect": "fade",
                "fade": { "blur": 0, "scale": 0 },
                "loop": true,
                "gap": "0px",
                "slidesPerView": 1,
                "navigation": {
                  "showButtons": {{ show_nav | json }},
                  "showPagination": {{ show_nav | json }}
                },
                "syncWith": "#{{ content_carousel_id }}"
              }
            </script>

            <tarot-viewport>
              <tarot-track>
                {% for block in section.blocks %}
                  {%- assign b = block.settings -%}
                  <tarot-slide {{ block.shopify_attributes }}>
                    <div class="relative overflow-hidden h-full">
                      {% if b.image != blank %}
                        {%- capture content -%}
                          {{- b.image
                            | image_url: width: 1200
                            | image_tag:
                                class: 'w-full h-full object-cover',
                                loading: 'lazy',
                                sizes: '(min-width: 1024px) 50vw, 100vw',
                                widths: '400, 600, 800, 1000, 1200'
                          -}}
                        {%- endcapture -%}
                        {%- render 'media-loader', content: content, show_skeleton: true -%}
                      {% else %}
                        {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full object-cover' }}
                      {% endif %}
                    </div>
                  </tarot-slide>
                {% endfor %}
              </tarot-track>
            </tarot-viewport>

            {% # Mobile-only nav vertically centered on image %}
            <div class="lg:hidden absolute inset-x-2 top-1/2 -translate-y-1/2 flex justify-between z-2 pointer-events-none [&>button]:pointer-events-auto">
              {% render 'carousel-buttons' %}
            </div>

            {% # Mobile-only pagination dots, lower-right on top of image %}
            {% if section.blocks.size > 1 %}
              <div data-tarot-pagination 
                class="lg:hidden absolute bottom-0 right-0 z-2 px-gutter py-sm"></div>
            {% endif %}
          </tarot-carousel>

          {% # Right-edge gradient overlay — fades image into right column bg (desktop only) %}
          <div class="hidden lg:block absolute inset-y-0 right-0 w-1/4 z-1 pointer-events-none"
            style="background: linear-gradient(to right, transparent, oklch(var(--color-background)));"></div>
        </div>

        {% # Right column — heading + content carousel + desktop nav %}
        <div class="h-full w-full flex items-center justify-center px-gutter py-lg lg:p-lg">
          <div class="w-full max-w-[560px]">

            <tarot-carousel id="{{ content_carousel_id }}">

              <div class="flex items-start justify-between w-full gap-md mb-sm">
                <div>
                  <div role="heading" aria-level="2" class="fs-display-2 text-pretty">{{ s.heading | escape }}</div>
                  {% if s.richtext != blank %}
                    <div class="rte text-pretty mt-xs">{{ s.richtext }}</div>
                  {% endif %}
                </div>
                {% if section.blocks.size > 1 %}
                  <p data-content-carousel-page="{{ content_carousel_id }}"
                    class="fs-display-5 text-heading text-base shrink-0">
                    1 / {{ section.blocks.size }}
                  </p>
                {% endif %}
              </div>


              <script type="application/json" data-tarot-options>
                {
                  "effect": "carousel",
                  "loop": true,
                  "gap": "16px",
                  "slidesPerView": 1,
                  "navigation": {
                    "showButtons": {{ show_nav | json }},
                    "showPagination": false
                  }
                }
              </script>

              <tarot-viewport>
                <tarot-track>
                  {% for block in section.blocks %}
                    {%- assign b = block.settings -%}
                    <tarot-slide {{ block.shopify_attributes }}>
                      <div class="flex flex-col gap-sm">
                        {% for i in (1..3) %}
                          {%- assign product_key = 'product_' | append: i -%}
                          {%- assign label_key = product_key | append: '_color_label' -%}
                          {%- assign slot_product = b[product_key] -%}
                          {%- assign slot_label = b[label_key] -%}
                          {% if slot_product != blank %}
                            {% render 'product-card-horizontal',
                              product: slot_product,
                              preferred_color_label: slot_label,
                              card_color_scheme: s.card_color_scheme %}
                          {% endif %}
                        {% endfor %}
                      </div>
                    </tarot-slide>
                  {% endfor %}
                </tarot-track>
              </tarot-viewport>

              {% # Desktop-only nav under cards %}
              <div class="hidden lg:flex justify-end gap-4 py-4 mt-2 w-full">
                {% render 'carousel-buttons' %}
              </div>
            </tarot-carousel>

          </div>
        </div>

      </div>
    {% endif %}

  </div>
</section>

{% if section.blocks.size > 1 %}
  <script>
    (function () {
      const carouselId = {{ content_carousel_id | json }};
      const carousel = document.getElementById(carouselId);
      const counter = document.querySelector('[data-content-carousel-page="' + carouselId + '"]');
      if (!carousel || !counter) return;

      customElements.whenDefined('tarot-carousel').then(function () {
        function update() {
          const state = carousel.state;
          if (!state) return;
          counter.textContent = (state.pageIndex + 1) + ' / ' + state.pageCount;
        }
        carousel.on('page-index:changed', update);
        update();
      });
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Shop the Look",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme" },
    { "type": "color_scheme", "id": "card_color_scheme", "label": "Product card color scheme" },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop the Look" },
    { "type": "inline_richtext", "id": "richtext", "label": "Text" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },

        { "type": "header", "content": "Product 1" },
        { "type": "product", "id": "product_1", "label": "Product" },
        { "type": "text", "id": "product_1_color_label", "label": "Color variant label", "info": "Type the exact color name (e.g. \"Caribbean Blue\") to lock that variant. Leave blank for first available." },

        { "type": "header", "content": "Product 2" },
        { "type": "product", "id": "product_2", "label": "Product" },
        { "type": "text", "id": "product_2_color_label", "label": "Color variant label" },

        { "type": "header", "content": "Product 3" },
        { "type": "product", "id": "product_3", "label": "Product" },
        { "type": "text", "id": "product_3_color_label", "label": "Color variant label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the Look",
      "category": "Media & Content",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["*"]
  }
}
{% endschema %}
