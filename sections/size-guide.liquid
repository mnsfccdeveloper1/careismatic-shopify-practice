<!-- section: size-guide -->
{%- comment -%}
  Single shared size-guide dialog. The chart is fetched on demand via
  <html-fetcher section="sapi-size-chart">, keyed by the triggering product's
  URL — so it adapts to the main product, set/bundle components, and every
  Complete-the-Look product without pre-rendering panels.
{%- endcomment -%}

<openable-component data-close-on-outside-click>
  <dialog
    data-openable
    id="size-guide-dialog"
    class="dialog-popup w-full max-w-[100vw] md:max-w-[800px] rounded-theme py-md px-gutter">

    <html-fetcher section="sapi-size-chart" use-view-transition>

      {%- # Loading skeleton — mirrors snippets/size-guide-content.liquid -%}
      <div class="hidden" data-html-fetcher-loading-class="!block">

        {%- # Title row — matches the rendered dialog heading -%}
        <div class="flex items-start justify-between pb-sm">
          <div class="h-7 w-2/5 bg-grey-light rounded"></div>
          {% render 'dialog-close-button', position: 'float' %}
        </div>

        {%- # Size chart table -%}
        <div class="flex flex-col gap-2">
          {%- # Header row -%}
          <div class="grid grid-cols-5 gap-2">
            {%- for col in (1..5) -%}
              <div class="h-5 bg-grey-light rounded"></div>
            {%- endfor -%}
          </div>
          {%- # Body rows -%}
          {%- for row in (1..4) -%}
            <div class="grid grid-cols-5 gap-2">
              {%- for col in (1..5) -%}
                <div class="h-4 bg-grey-light rounded"></div>
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>

        {%- # Image + "How to measure" instructions -%}
        <div class="flex flex-col md:flex-row gap-6 mt-sm">
          <div class="order-2 md:order-1 md:w-1/2">
            <div class="h-48 md:h-64 w-full bg-grey-light rounded"></div>
          </div>
          <div class="order-1 md:order-2 flex flex-col gap-3 md:w-1/2">
            <div class="h-5 w-40 bg-grey-light rounded"></div>
            <div class="h-3 bg-grey-light rounded"></div>
            <div class="h-3 bg-grey-light rounded"></div>
            <div class="h-3 bg-grey-light rounded"></div>
            <div class="h-3 w-3/4 bg-grey-light rounded"></div>
          </div>
        </div>
      </div>

      {%- # Content area -%}
      <div data-html-fetcher-area data-html-fetcher-loading-class="hidden"></div>

    </html-fetcher>
  </dialog>
</openable-component>

{% schema %}
{
  "name": "Size Guide",
  "limit": 1
}
{% endschema %}
