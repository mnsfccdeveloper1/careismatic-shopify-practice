<!-- section: collection-list-carousel -->

{%- liquid
  assign s = section.settings
  assign section_id = section.id | split: '_' | last

  assign container_max_width = ''
  if s.use_max_width
    assign container_max_width = 'max-w-container'
  endif
-%}

<section class="color-{{ s.color_scheme }} py-md overflow-hidden px-gutter">
  <div class="mx-auto {{ container_max_width }}">

    <div class="flex justify-between items-center gap-4 mb-sm">
      <div class="flex-1 min-w-0">
        {% if s.eyebrow != blank %}
          <p class="fs-eyebrow">{{ s.eyebrow | escape }}</p>
        {% endif %}

        {% if s.heading != blank %}
          <h2 class="fs-display-3 mb-0">{{ s.heading | escape }}</h2>
        {% endif %}

        {% if s.richtext != blank %}
          <div class="rte text-pretty">{{ s.richtext }}</div>
        {% endif %}
      </div>

      <div class="hidden md:has-[button:not(:disabled)]:flex items-center gap-4 shrink-0">
        {% render 'carousel-buttons', unique_id: section_id %}
      </div>
    </div>

    {% if section.blocks.size > 0 %}
      <tarot-carousel>
        <script type="application/json" data-tarot-options>
          {
            "effect": "carousel",
            "loop": {{ s.carousel_loop | json }},
            "gap": "8px",
            "slidesPerView": 2,
            "navigation": {
              "showPagination": false,
              "previousButtonSelector": "#prev-{{ section_id }}",
              "nextButtonSelector": "#next-{{ section_id }}"
            },
            "breakpoints": {
              "768": { "slidesPerView": {{ s.slides_per_view_tablet | json }} },
              "1024": { "slidesPerView": {{ s.slides_per_view_laptop | json }} },
              "1280": { "slidesPerView": {{ s.slides_per_view_desktop | json }} }
            }
          }
        </script>

        <tarot-viewport class="overflow-visible">
          <tarot-track>
            {% for block in section.blocks %}
              {%- liquid
                assign b = block.settings
                assign collection = b.collection
                assign card_title = b.custom_title | default: collection.title
                assign card_image = b.image | default: collection.featured_image
                assign card_url = collection.url | default: '#'
              -%}
              <tarot-slide {{ block.shopify_attributes }}>
                <a href="{{ card_url }}" 
                  class="block group no-underline pb-sm">
                  <div class="relative aspect-square overflow-hidden rounded-theme">
                    {% if card_image != blank %}
                      {%- capture content -%}
                        {{- card_image
                          | image_url: width: 800
                          | image_tag:
                              alt: '',
                              class: 'w-full h-full object-cover transition group-hover:scale-105',
                              loading: 'lazy',
                              sizes: '(min-width: 1024px) 25vw, 50vw',
                              widths: '300, 500, 700, 800'
                        -}}
                      {%- endcapture -%}
                      {%- render 'media-loader', content: content, show_skeleton: true -%}
                    {% else %}
                      {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
                    {% endif %}
                  </div>
                  <p class="fs-body-lg text-left mt-2">
                    {{ card_title | escape }}
                  </p>
                </a>
              </tarot-slide>
            {% endfor %}
          </tarot-track>
        </tarot-viewport>
      </tarot-carousel>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Collection List Carousel",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme" },
    { "type": "checkbox", "id": "use_max_width", "label": "Use container max-width", "default": true },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Collection" },
    { "type": "inline_richtext", "id": "richtext", "label": "Text" },

    { "type": "header", "content": "Carousel" },
    { "type": "checkbox", "id": "carousel_loop", "label": "Loop carousel", "default": false },
    { "type": "range", "id": "slides_per_view_tablet", "label": "Slides per view (tablet)", "min": 1, "max": 5, "step": 1, "default": 2 },
    { "type": "range", "id": "slides_per_view_laptop", "label": "Slides per view (laptop)", "min": 1, "max": 6, "step": 1, "default": 3 },
    { "type": "range", "id": "slides_per_view_desktop", "label": "Slides per view (desktop)", "min": 1, "max": 8, "step": 1, "default": 6 }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "custom_title", "label": "Custom title", "info": "Overrides the collection title" },
        { "type": "image_picker", "id": "image", "label": "Image override", "info": "Overrides the collection image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List Carousel",
      "category": "Media & Content",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["*"]
  }
}
{% endschema %}
